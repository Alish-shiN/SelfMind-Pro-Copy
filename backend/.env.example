# SelfMind Pro backend environment template
# Copy this file to backend/.env for local development.

PROJECT_NAME="SelfMind Pro API"
API_V1_STR=/api/v1

# Option A: local/docker PostgreSQL via separate variables.
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=selfmind_db

# Option B: cloud PostgreSQL connection string.
# If DATABASE_URL is set, it overrides POSTGRES_* variables.
# Examples:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# Use this when your cloud provider requires SSL but the URL does not include ?sslmode=require.
# Common values: require, verify-full.
DB_SSL_MODE=

SECRET_KEY=change-me-use-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

OPENAI_API_KEY=change-me
OPENAI_MODEL=gpt-5-mini

# JSON list for explicit origins, or ["*"] for local/demo mode.
BACKEND_CORS_ORIGINS=["*"]
